# 火山引擎 API 配置
ARK_API_KEY=xxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_REGION=cn-beijing
MODEL=doubao-1-5-pro-32k-250115
EMBEDDER=xxxx

# Milvus 向量数据库配置
MILVUS_URI=localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=hotwords

# 服务器配置
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# 文件上传配置
MAX_UPLOAD_SIZE=10485760  # 10MB
UPLOAD_DIR=./uploads

# RAG 配置
EMBEDDING_DIM=2048
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# 智能知识增强配置
# 当本地知识库相似度低于阈值时，自动触发联网搜索并保存结果
ENABLE_AUTO_SEARCH=true          # 是否启用自动联网搜索
SIMILARITY_THRESHOLD=1.0         # 相似度阈值（L2距离，越小越相似，建议1.0-2.0）
AUTO_SAVE_SEARCH_RESULT=true    # 是否自动保存搜索结果到知识库

# LLM 配置
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
