# 火山引擎 API 配置
ARK_API_KEY=xxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_REGION=cn-beijing
MODEL=doubao-1-5-pro-32k-250115
EMBEDDER=xxxx

# Milvus 向量数据库配置
MILVUS_URI=localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=hotwords_collection

# 服务器配置
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT_SEC=15
SERVER_WRITE_TIMEOUT_SEC=60
SERVER_SHUTDOWN_TIMEOUT_SEC=10
TRUSTED_PROXIES=
CORS_ALLOWED_ORIGINS=*

# 文件上传配置
MAX_UPLOAD_SIZE=10485760  # 10MB
UPLOAD_DIR=./uploads

# RAG 配置
EMBEDDING_DIM=2048
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
MAX_CONTEXT_DOCS=5
MAX_CONTEXT_CHARS=4000
MAX_SCORE_DELTA=1.0

# 智能知识增强配置
# 当本地知识库相似度低于阈值时，自动触发联网搜索并保存结果
ENABLE_AUTO_SEARCH=true          # 是否启用自动联网搜索
SIMILARITY_THRESHOLD=1.0         # 相似度阈值（L2距离，越小越相似，建议1.0-2.0）
AUTO_SAVE_SEARCH_RESULT=true    # 是否自动保存搜索结果到知识库
AUTO_SAVE_MIN_CHARS=120        # 自动保存最小内容长度，过短结果不入库

# 安全配置
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Ollama 本地模型（可选）
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:0.6b
