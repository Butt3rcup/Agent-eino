# Ark API
ARK_API_KEY=xxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_REGION=cn-beijing
MODEL=doubao-1-5-pro-32k-250115
EMBEDDER=xxxx

# Milvus
MILVUS_URI=localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=hotwords_collection

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT_SEC=15
SERVER_WRITE_TIMEOUT_SEC=60
SERVER_SHUTDOWN_TIMEOUT_SEC=10
TRUSTED_PROXIES=
CORS_ALLOWED_ORIGINS=*

# Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
PDF_UPLOAD_ENABLED=false
UPLOAD_TASK_QUEUE_SIZE=8
UPLOAD_TASK_WORKERS=2

# RAG
EMBEDDING_DIM=2048
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
MAX_CONTEXT_DOCS=5
MAX_CONTEXT_CHARS=4000
MAX_SCORE_DELTA=1.0

# Smart retrieval
ENABLE_AUTO_SEARCH=true
SIMILARITY_THRESHOLD=1.0
AUTO_SAVE_SEARCH_RESULT=true
AUTO_SAVE_MIN_CHARS=120
ASYNC_KNOWLEDGE_PERSIST=true
PERSIST_QUEUE_SIZE=16
QUERY_CACHE_SIZE=256
QUERY_CACHE_TTL_SECONDS=30

# Security
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
QUERY_DEFAULT_TIMEOUT_SEC=45
QUERY_DEFAULT_RATE_LIMIT_RPS=8
QUERY_DEFAULT_RATE_LIMIT_BURST=16
QUERY_MODE_TIMEOUTS=multi-agent:60,graph_rag:60,graph_multi:75
QUERY_MODE_RATE_LIMIT_RPS=multi-agent:4,graph_rag:4,graph_multi:3
QUERY_MODE_RATE_LIMIT_BURST=multi-agent:8,graph_rag:8,graph_multi:6

# Optional local Ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:0.6b
